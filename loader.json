    private getPriorityColor(priority: '高' | '中' | '低' | ''): ResourceColor {
        switch (priority) {
            case '高':
                return '#FF3B30';
            case '中':
                return '#FF9500';
            case '低':
                return '#34C759';
            case '':
                return '#FF9500';
            default:
                return '#999999';
        }
    }
    private sortObjectKeys(keys: string[]): string[] {
