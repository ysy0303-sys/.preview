    private parseDate(dateStr: string): DateInfo {
        if (!dateStr) {
            return { year: '2026', month: '01', day: '01' };
        }
        let parts = dateStr.split('-');
        return {
            year: parts[0],
            month: parts[1].padStart(2, '0'),
            day: parts[2].padStart(2, '0')
        };
    }
